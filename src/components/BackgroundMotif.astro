---
interface Props {
  density?: "quiet" | "standard";
}

const { density = "standard" } = Astro.props;
---

<div class={`background-motif background-motif--${density}`} aria-hidden="true">
  <span></span>
  <span></span>
</div>

<style>
  .background-motif {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .background-motif::before {
    position: absolute;
    right: min(5vw, 4rem);
    top: 10%;
    width: clamp(16rem, 36vw, 32rem);
    aspect-ratio: 1;
    content: "";
    border: 1px solid rgba(155, 166, 149, 0.14);
    border-radius: 50%;
    box-shadow:
      inset 0 0 0 4rem rgba(155, 166, 149, 0.018),
      inset 0 0 0 8rem rgba(155, 166, 149, 0.014);
  }

  .background-motif span {
    position: absolute;
    display: block;
    background: rgba(155, 166, 149, 0.16);
  }

  .background-motif span:first-child {
    right: 10%;
    top: 32%;
    width: 32rem;
    height: 1px;
    transform: rotate(-18deg);
  }

  .background-motif span:last-child {
    right: 24%;
    top: 11%;
    width: 1px;
    height: 30rem;
    transform: rotate(18deg);
  }

  .background-motif--quiet {
    opacity: 0.5;
  }
</style>

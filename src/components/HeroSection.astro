---
import { siteConfig } from "../config/site";
import BackgroundMotif from "./BackgroundMotif.astro";

interface Props {
  eyebrow?: string;
  title: string;
  text: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  eyebrow = "Arkham Advisory",
  title,
  text,
  primaryLabel = "Work with me",
  primaryHref = "/contact/",
  secondaryLabel = "Read the field notes",
  secondaryHref = "/writing/",
} = Astro.props;
---

<section class="hero-section">
  <BackgroundMotif density="quiet" />
  <div class="hero-section__inner container">
    <div class="hero-section__copy">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p>{text}</p>
      <div class="hero-section__actions">
        <a class="button" href={primaryHref}>{primaryLabel}</a>
        <a class="button button--ghost" href={secondaryHref}>{secondaryLabel}</a>
      </div>
    </div>
    <div class="hero-section__visual" aria-hidden="true">
      <picture>
        <source srcset={siteConfig.assets.hero.main} type="image/webp" />
        <img
          src={siteConfig.assets.hero.fallback}
          alt=""
          width="1920"
          height="1080"
          decoding="async"
          fetchpriority="high"
          sizes="(max-width: 900px) calc(100vw - 2rem), 44vw"
        />
      </picture>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    overflow: hidden;
    padding-block: clamp(2.5rem, 5vw, 5rem);
  }

  .hero-section__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(18rem, 0.8fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }

  .hero-section__copy {
    display: grid;
    gap: 1.3rem;
  }

  .hero-section__copy > p:not(.eyebrow) {
    max-width: 46rem;
    color: var(--text-secondary);
    font-size: clamp(1.1rem, 1rem + 0.5vw, 1.35rem);
  }

  .hero-section__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 0.4rem;
  }

  .hero-section__visual {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    background: var(--bg-panel);
    box-shadow: var(--shadow-deep);
  }

  .hero-section__visual::after {
    position: absolute;
    inset: 0;
    content: "";
    background:
      linear-gradient(90deg, rgba(15, 26, 23, 0.16), rgba(15, 26, 23, 0.68)),
      linear-gradient(0deg, rgba(15, 26, 23, 0.78), transparent 52%);
  }

  .hero-section__visual picture,
  .hero-section__visual img {
    width: 100%;
    height: 100%;
  }

  .hero-section__visual img {
    object-fit: cover;
    object-position: 50% 50%;
  }

  @media (max-width: 900px) {
    .hero-section__inner {
      grid-template-columns: 1fr;
    }

    .hero-section__visual {
      aspect-ratio: 16 / 9;
    }
  }
</style>

---
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
}

const { eyebrow, title, text } = Astro.props;
---

<section class="page-hero">
  <div class="container page-hero__inner">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    {text && <p>{text}</p>}
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    padding-block: clamp(4rem, 9vw, 8rem) clamp(3rem, 7vw, 5rem);
    border-bottom: 1px solid var(--border-subtle);
  }

  .page-hero__inner {
    display: grid;
    gap: 1rem;
    max-width: 900px;
  }

  .page-hero p:not(.eyebrow) {
    max-width: var(--text-width);
    color: var(--text-secondary);
    font-size: clamp(1.1rem, 1rem + 0.45vw, 1.3rem);
  }
</style>

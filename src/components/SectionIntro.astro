---
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
  align?: "left" | "center";
}

const { eyebrow, title, text, align = "left" } = Astro.props;
---

<div class={`section-intro section-intro--${align}`}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2>{title}</h2>
  {text && <p class="muted">{text}</p>}
  <slot />
</div>

<style>
  .section-intro {
    display: grid;
    gap: 1rem;
    max-width: var(--text-width);
  }

  .section-intro--center {
    margin-inline: auto;
    text-align: center;
  }

  .section-intro :global(.eyebrow) {
    margin-bottom: -0.15rem;
  }

  .section-intro p {
    font-size: clamp(1.05rem, 1rem + 0.35vw, 1.25rem);
  }
</style>

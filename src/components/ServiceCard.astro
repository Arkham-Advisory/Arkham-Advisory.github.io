---
interface Props {
  title: string;
  summary: string;
  href?: string;
  label?: string;
}

const { title, summary, href = "/advisory/", label = "Explore advisory" } = Astro.props;
---

<article class="service-card">
  <div>
    <p class="service-card__mark" aria-hidden="true"></p>
    <h3>{title}</h3>
    <p>{summary}</p>
  </div>
  {href && <a href={href}>{label}</a>}
</article>

<style>
  .service-card {
    display: grid;
    gap: 1.5rem;
    align-content: space-between;
    min-height: 100%;
    padding: clamp(1.25rem, 3vw, 1.75rem);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    background: rgba(13, 26, 28, 0.78);
    transition:
      border-color 220ms ease,
      background 220ms ease,
      box-shadow 220ms ease;
  }

  .service-card:hover {
    border-color: var(--border-strong);
    background: rgba(18, 33, 35, 0.92);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.28);
  }

  .service-card__mark {
    width: 2rem;
    height: 1px;
    margin-bottom: 1.25rem;
    background: var(--arkham-sage);
  }

  .service-card h3 {
    margin-bottom: 0.8rem;
  }

  .service-card p:not(.service-card__mark) {
    color: var(--text-secondary);
  }

  .service-card a {
    justify-self: start;
    color: var(--arkham-sage);
    font-size: 0.92rem;
    font-weight: 700;
    text-decoration: none;
  }
</style>

---
import { siteConfig } from "../config/site";
---

<footer class="site-footer">
  <div class="site-footer__inner container">
    <div class="site-footer__brand">
      <img
        src={siteConfig.assets.logos.primarySvg}
        alt="Arkham Advisory"
        width="900"
        height="900"
        loading="lazy"
        decoding="async"
      />
      <p>Senior judgment under uncertainty, for leaders making consequential decisions in data, AI, and transformation.</p>
    </div>

    <nav class="site-footer__nav" aria-label="Footer navigation">
      {
        siteConfig.nav.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))
      }
    </nav>

    <div class="site-footer__links">
      <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
      <a href={siteConfig.arkhamTimesUrl} rel="noreferrer">Arkham Times</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border-subtle);
    background:
      radial-gradient(circle at 88% 18%, rgba(155, 166, 149, 0.09), transparent 23rem),
      #0c1512;
  }

  .site-footer__inner {
    display: grid;
    grid-template-columns: minmax(18rem, 1.4fr) 0.7fr 0.9fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .site-footer__brand {
    max-width: 32rem;
  }

  .site-footer__brand img {
    width: min(14rem, 62vw);
    height: auto;
    margin-bottom: 1.5rem;
  }

  .site-footer__brand p {
    color: var(--text-secondary);
  }

  .site-footer__nav,
  .site-footer__links {
    display: grid;
    gap: 0.65rem;
  }

  .site-footer a {
    color: var(--text-secondary);
    text-decoration: none;
  }

  .site-footer a:hover {
    color: var(--text-primary);
  }

  @media (max-width: 820px) {
    .site-footer__inner {
      grid-template-columns: 1fr;
    }
  }
</style>

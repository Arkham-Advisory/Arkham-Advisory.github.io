---
import CTASection from "../components/CTASection.astro";
import MonogramBadge from "../components/MonogramBadge.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="The map runs out here | Arkham Advisory"
  description="This page could not be found."
>
  <section class="not-found">
    <div class="container not-found__inner">
      <MonogramBadge />
      <div>
        <p class="eyebrow">404</p>
        <h1>The map runs out here.</h1>
        <p>
          The page you were looking for is not on this chart. Return to the
          homepage, or continue through the advisory routes.
        </p>
      </div>
      <CTASection
        title="Back to known waters."
        primaryLabel="Return home"
        primaryHref="/"
        secondaryLabel="Contact"
        secondaryHref="/contact/"
      />
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: 66vh;
    display: grid;
    align-items: center;
    padding-block: clamp(4rem, 10vw, 8rem);
  }

  .not-found__inner {
    display: grid;
    gap: clamp(2rem, 5vw, 3rem);
    justify-items: start;
  }

  .not-found h1 {
    margin-top: 0.75rem;
  }

  .not-found p:not(.eyebrow) {
    max-width: var(--text-width);
    margin-top: 1rem;
    color: var(--text-secondary);
    font-size: clamp(1.08rem, 1rem + 0.4vw, 1.25rem);
  }
</style>
